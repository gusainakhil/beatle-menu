{
    "name": "beetle/analytics-dashboard",
    "description": "Owner Reports Dashboard for Beetle Analytics in plain PHP using MVC pattern",
    "type": "project",
    "require": {
        "php": ">=8.2",
        "vlucas/phpdotenv": "^5.6"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    }
}
